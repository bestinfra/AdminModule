{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "ESNext",
        "useDefineForClassFields": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "skipLibCheck": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",

        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": true,

        /* Path Aliases */
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "@api/*": ["src/api/*"],
            "@components/*": ["src/components/*"],
            "@pages/*": ["src/pages/*"],
            "@pages_v2/*": ["src/pages_v2/*"],
            "@graphs/*": ["src/graphs/*"],
            "@context/*": ["src/context/*"],
            "@providers/*": ["src/providers/*"],
            "@utils/*": ["src/utils/*"],
            "@hooks/*": ["src/hooks/*"],
            "@assets/*": ["src/assets/*"],
            "@types/*": ["src/types/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "src/export_pages"]
}
