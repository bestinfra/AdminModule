// Generate dynamic menu items based on selected modules
const generateMenuItems = (modules: string[] = []) => {
  const mandatoryMenus = [];

  // Add Consumers only if consumer module is selected
  if (modules.includes('consumer')) {
    mandatoryMenus.push({
      title: 'Consumers',
      icon: '/icons/units.svg',
      link: '/consumers',
    });
  }

  // Create dynamic dashboard menu logic
  const dashboardSubmenus = [];
  if (modules.includes('consumer_dashboard')) {
    dashboardSubmenus.push({
      title: 'Consumer Dashboard',
      link: '/consumer-dashboard',
    });
  }
  if (modules.includes('dtr_dashboard')) {
    dashboardSubmenus.push({
      title: 'DTR Dashboard',
      link: '/dtr-dashboard',
    });
  }

  // Smart dashboard menu logic
  if (dashboardSubmenus.length === 0) {
    // No dashboard modules selected - add default dashboard
    mandatoryMenus.push({
      title: 'Dashboard',
      icon: '/icons/dashboard.svg',
      link: '/dashboard',
    });
  } else if (dashboardSubmenus.length === 1) {
    // Only one dashboard selected - make it the main dashboard
    const singleDashboard = dashboardSubmenus[0];
    mandatoryMenus.push({
      title: singleDashboard.title,
      icon: '/icons/dashboard.svg',
      link: singleDashboard.link,
    });
  } else {
    // Multiple dashboards selected - create parent with submenus
    mandatoryMenus.push({
      title: 'Dashboard',
      icon: '/icons/dashboard.svg',
      link: '/dashboard',
      hasSubmenu: true,
      submenu: dashboardSubmenus,
    });
  }

  const moduleMenuMap = {
    tickets: {
