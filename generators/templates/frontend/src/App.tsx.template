      submenu: [
        // {
        //   title: 'Data Logger Master',
        //   link: '/data-logger-master',
        // },
        {
          title: 'Meter List',
          link: '/meters',
        },
      ],
    },
    user_management_default: {
      title: 'Users',
      icon: '/icons/user.svg',
      link: '/users',
      hasSubmenu: true,
      submenu: [
        {
          title: 'Users',
          icon: '/icons/user-gear.svg',
          link: '/users',
        },
        {
          title: 'Role Management',
          icon: '/icons/roles.svg',
          link: '/role-management',
        },
      ],
    },
    dtr: {
      title: 'DTR Dashboard',
      icon: '/icons/transformer.svg',
