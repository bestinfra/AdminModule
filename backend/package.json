{
  "name": "admin-module-backend",
  "version": "1.0.0",
  "description": "Backend server for AdminModule",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:migrate-from-json": "node scripts/migrate-to-postgres.js",
    "meter:generate": "prisma generate --schema=./prisma/schema.meter.prisma",
    "meter:push": "prisma db push --schema=./prisma/schema.meter.prisma",
    "meter:studio": "prisma studio --schema=./prisma/schema.meter.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.18.2",
    "fs-extra": "^11.3.0",
    "jsonwebtoken": "^9.0.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "prisma": "^5.7.1"
  }
}
